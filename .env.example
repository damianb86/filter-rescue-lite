# Filter Rescue Lite
# Copy to .env for local development. Do not commit real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/filter_rescue_lite
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development

# Docker deployment placeholders
COMPOSE_PROJECT_NAME=filter-rescue-lite
APP_DB_NAME=filter_rescue_lite
APP_DB_USER=filter_rescue_lite_user
APP_DB_PASSWORD=replace_me
APP_HOST=filter-rescue-lite.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
